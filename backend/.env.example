PORT=3000
# CANSAT ground receiver: ESP32 WROOM-32 + RFM69HCW 433 MHz
# The ESP32 bridges RFM69 → USB Serial to this laptop at 115200 baud.
# firmware: firmware/ground-station/src/main.cpp
SERIAL_PORT_CANSAT=/dev/ttyUSB0
# NRC receiver or direct Heltec USB: SX1262 868 MHz telemetry, 115200 baud
SERIAL_PORT_NRC=/dev/ttyUSB1
SERIAL_BAUD_CANSAT=115200
SERIAL_BAUD_NRC=115200
ENABLE_NRC_LIVE=false
DB_FILE=./flight.db
DASHBOARD_PATH=../dashboard/ground-station.html
ROVER_IP=192.168.4.1
ROVER_PORT=5000
ROVER_TIMEOUT_MS=800
ROVER_CONTROL_TOKEN=
SIM_MODE=false
ENABLE_SIM_FALLBACK=false
LOG_PACKETS=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500,null
SIGNAL_TIMEOUT_MS=5000
SERIAL_RECONNECT_MS=3000
SD_UPLOAD_MAX_FILE_BYTES=5242880
SD_UPLOAD_MAX_ROWS=50000
LOG_LEVEL=info
